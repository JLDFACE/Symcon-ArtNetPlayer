{
  "elements": [
    {
      "type": "ValidationTextBox",
      "name": "Host",
      "caption": "Host/IP (NAS-Tool)"
    },
    {
      "type": "NumberSpinner",
      "name": "Port",
      "caption": "Port",
      "minimum": 1,
      "maximum": 65535
    },
    {
      "type": "NumberSpinner",
      "name": "Poll",
      "caption": "Abfrage-Intervall (s)",
      "minimum": 1,
      "maximum": 60
    }
  ],
  "actions": [
    {
      "type": "Button",
      "caption": "Jetzt abfragen",
      "onClick": "ANP_Poll($id);"
    },
    {
      "type": "Label",
      "caption": "Danach je Player eine 'Art-Net Player'-Instanz anlegen und dort die Player-ID setzen."
    }
  ],
  "status": [
    { "code": 102, "icon": "active", "caption": "Verbunden" },
    { "code": 104, "icon": "inactive", "caption": "Host/Port nicht konfiguriert" },
    { "code": 201, "icon": "error", "caption": "Tool nicht erreichbar" }
  ]
}
